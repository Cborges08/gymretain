# Supabase — get from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — NEVER expose client-side (per D-09)
# Required by Phase 7 cron job for RLS bypass
# Get from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend Email Service — get from: resend.com > API Keys
# Free tier: 100 emails/day (sufficient for MVP)
RESEND_API_KEY=re_your-resend-api-key

# Cron Secret — generate with: openssl rand -hex 32
# Used to authenticate Vercel cron job calls to /api/cron/detect-churn
CRON_SECRET=your-32-char-hex-secret-here
